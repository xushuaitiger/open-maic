# ============================================================
# OpenMAIC Python Backend — Environment Variables
# Copy to .env and fill in your keys.
# Alternatively, configure via server-providers.yml
# ============================================================

# Default LLM model (format: "provider:model-id")
# Examples: openai:gpt-4o-mini  anthropic:claude-3-5-haiku-20241022  google:gemini-2.0-flash
DEFAULT_MODEL=openai:gpt-4o-mini

# ── LLM Providers ───────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=                  # optional override

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=               # optional override

GOOGLE_API_KEY=
GOOGLE_BASE_URL=                  # optional override

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1

MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1

GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ── TTS Providers ───────────────────────────────────────────
TTS_OPENAI_API_KEY=
TTS_OPENAI_BASE_URL=

TTS_AZURE_API_KEY=
TTS_AZURE_BASE_URL=               # e.g. https://<region>.tts.speech.microsoft.com

TTS_GLM_API_KEY=
TTS_QWEN_API_KEY=

# ── ASR Providers ───────────────────────────────────────────
ASR_OPENAI_API_KEY=
ASR_OPENAI_BASE_URL=

ASR_QWEN_API_KEY=

# ── PDF Providers ───────────────────────────────────────────
PDF_MINERU_BASE_URL=              # e.g. http://localhost:8000
PDF_MINERU_API_KEY=               # optional

# ── Image Generation ────────────────────────────────────────
IMAGE_SEEDREAM_API_KEY=
IMAGE_QWEN_IMAGE_API_KEY=

# ── Video Generation ────────────────────────────────────────
VIDEO_SEEDANCE_API_KEY=
VIDEO_KLING_API_KEY=

# ── Web Search ──────────────────────────────────────────────
TAVILY_API_KEY=

# ── Storage ─────────────────────────────────────────────────
# Directory where classroom data is stored (default: ./data/classrooms)
CLASSROOMS_DIR=

# ── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
